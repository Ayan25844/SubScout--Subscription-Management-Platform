    "definitions": {
        "Category": {
            "description": "Metadata used to organize and filter subscriptions",
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "created_by": {
                    "type": "string",
                    "format": "uuid"
                },
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "name": {
                    "type": "string",
                    "example": "Cloud"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "updated_by": {
                    "type": "string",
                    "format": "uuid"
                }
            }
        },
        "Category_DTO": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Cloud"
                }
            }
        },
        "Login": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string",
                    "format": "email",
                    "example": "xyz@gmail.com"
                },
                "password": {
                    "type": "string",
                    "format": "password"
                }
            }
        },
        "Subscription": {
            "description": "Detailed information about a user's subscription",
            "type": "object",
            "properties": {
                "billing_cycle": {
                    "type": "string",
                    "example": "monthly"
                },
                "category_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "monthly_cost": {
                    "type": "number",
                    "format": "float",
                    "example": 15.99
                },
                "next_billing_date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "service_name": {
                    "type": "string",
                    "example": "Catalog service"
                },
                "status": {
                    "type": "string",
                    "example": "active"
                },
                "trial_end_date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "user_id": {
                    "type": "string",
                    "format": "uuid"
                }
            }
        },
        "Subscription_DTO": {
            "type": "object",
            "required": [
                "category_id",
                "monthly_cost",
                "next_billing_date",
                "service_name"
            ],
            "properties": {
                "billing_cycle": {
                    "type": "string",
                    "example": "monthly"
                },
                "category_id": {
                    "type": "string",
                    "format": "uuid"
                },
                "monthly_cost": {
                    "type": "number",
                    "format": "float",
                    "example": 15.99
                },
                "next_billing_date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "service_name": {
                    "type": "string",
                    "example": "Catalog service"
                },
                "trial_end_date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                }
            }
        },
        "Update_Subscription_Status": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "active"
                }
            }
        },
        "Update_User_Password": {
            "type": "object",
            "properties": {
                "new_password": {
                    "type": "string",
                    "format": "password"
                },
                "old_password": {
                    "type": "string",
                    "format": "password"
                }
            }
        },
        "Update_User_Profile": {
            "type": "object",
            "properties": {
                "currency": {
                    "type": "string",
                    "example": "INR"
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "example": "xyz@gmail.com"
                }
            }
        },
        "User": {
            "description": "Detailed information about a user's profile",
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                },
                "currency": {
                    "type": "string",
                    "example": "INR"
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "example": "xyz@gmail.com"
                },
                "id": {
                    "type": "string",
                    "format": "uuid"
                },
                "role": {
                    "type": "string",
                    "example": "admin"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-03-09T12:00:00Z"
                }
            }
        },
        "User_DTO": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
